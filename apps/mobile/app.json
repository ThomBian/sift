{
  "expo": {
    "name": "Sift Mobile",
    "slug": "sift-mobile",
    "version": "1.0.0",
    "scheme": "siftmobile",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false
    },
    "android": {},
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-web-browser"
    ]
  }
}
