{
  "expo": {
    "name": "Sift Mobile",
    "slug": "sift-mobile",
    "version": "1.0.0",
    "scheme": "siftmobile",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "productivity.sift.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {},
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "31f92de1-6918-47df-a49a-c31356fcfc78"
      }
    }
  }
}
